{
  "name": "worknest-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "dotenv -e .env.local -- tsx watch src/index.ts",
    "dev:cloud": "dotenv -e .env.cloud -- tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:cloud": "dotenv -e .env.cloud -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:push:cloud": "dotenv -e .env.cloud -- prisma db push",
    "db:generate": "prisma generate",
    "db:setup": "dotenv -e .env.local -- prisma migrate dev && prisma generate",
    "db:view": "dotenv -e .env.local -- prisma studio",
    "db:view:cloud": "dotenv -e .env.cloud -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed:cloud": "dotenv -e .env.cloud -- tsx prisma/seed.ts",
    "dock:start": "docker compose up -d",
    "dock:stop": "docker compose stop",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.23",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.16.0",
    "@types/socket.io": "^3.0.1",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.11",
    "prisma": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.0.0",
    "@sentry/node": "^10.58.0",
    "@sentry/profiling-node": "^10.58.0",
    "@supabase/supabase-js": "^2.108.1",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.17.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.21.0",
    "yup": "^1.7.1",
    "zod": "^4.3.5"
  }
}
