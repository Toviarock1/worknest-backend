// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectRoles {
  owner
  member
}

enum TaskStatus {
  todo
  in_progress
  done
}

model User {
  id       String  @id @default(uuid())
  name     String?
  email    String  @unique
  password String

  projects       Project[]
  projectMembers ProjectMember[]
  tasks          Task[]
  messages       Message[]
  files          File[]
  taskComments   TaskComment[]
  reactions      MessageReaction[]

  createdAt DateTime @default(now())
}

model Project {
  id          String  @id @default(uuid())
  name        String
  ownerId     String
  description String?

  owner          User            @relation(fields: [ownerId], references: [id])
  projectMembers ProjectMember[]
  tasks          Task[]
  messages       Message[]
  files          File[]

  createdAt DateTime @default(now())
}

model ProjectMember {
  id        String       @id @default(uuid())
  userId    String
  projectId String
  role      ProjectRoles @default(member)

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String?

  status TaskStatus @default(todo)

  projectId    String
  assignedToId String?
  parentId     String?

  project    Project       @relation(fields: [projectId], references: [id])
  assignedTo User?         @relation(fields: [assignedToId], references: [id])
  comments   TaskComment[]
  files      File[]

  parent   Task?  @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[] @relation("TaskSubtasks")

  outgoingLinks TaskLink[] @relation("TaskLinkFrom")
  incomingLinks TaskLink[] @relation("TaskLinkTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([projectId, parentId])
}

enum TaskLinkType {
  blocks
  blocked_by
  related_to
}

model TaskLink {
  id           String       @id @default(uuid())
  fromTaskId   String
  toTaskId     String
  type         TaskLinkType
  createdById  String?

  fromTask    Task @relation("TaskLinkFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask      Task @relation("TaskLinkTo", fields: [toTaskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([fromTaskId, toTaskId, type])
  @@index([fromTaskId])
  @@index([toTaskId])
}

model TaskComment {
  id       String @id @default(uuid())
  content  String
  taskId   String
  authorId String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([taskId, createdAt])
}

model Message {
  id      String @id @default(uuid())
  content String

  projectId String
  senderId  String

  project   Project           @relation(fields: [projectId], references: [id])
  sender    User              @relation(fields: [senderId], references: [id])
  reactions MessageReaction[]

  createdAt DateTime @default(now())
}

model MessageReaction {
  id        String @id @default(uuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model File {
  id   String @id @default(uuid())
  name String
  url  String
  size Int

  projectId  String
  uploaderId String
  taskId     String?

  project  Project @relation(fields: [projectId], references: [id])
  uploader User    @relation(fields: [uploaderId], references: [id])
  task     Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([taskId])
}
